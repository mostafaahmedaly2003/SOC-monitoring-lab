<!-- ============================================================
     T-Pot Honeypot — Custom Wazuh Rules
     File location on Wazuh manager:
     /var/ossec/etc/rules/tpot_rules.xml
     Rule IDs: 200001–200010 (custom range, no conflicts)
     ============================================================ -->

<group name="honeypot,tpot,attack">

  <!-- Base rule: any T-Pot honeypot hit -->
  <rule id="200001" level="10">
    <decoded_as>tpot-json</decoded_as>
    <description>T-Pot: Honeypot hit recorded from $(srcip)</description>
    <group>honeypot</group>
  </rule>

  <!-- Cowrie SSH/Telnet brute force -->
  <rule id="200002" level="12">
    <if_sid>200001</if_sid>
    <field name="type">cowrie</field>
    <description>T-Pot: SSH/Telnet brute force attempt on Cowrie honeypot from $(srcip)</description>
    <group>honeypot,brute_force,authentication_failed</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Dionaea malware/exploit capture -->
  <rule id="200003" level="12">
    <if_sid>200001</if_sid>
    <field name="type">dionaea</field>
    <description>T-Pot: Malware/exploit attempt on Dionaea honeypot from $(srcip)</description>
    <group>honeypot,malware,exploit</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- Honeytrap generic port scan hit -->
  <rule id="200004" level="10">
    <if_sid>200001</if_sid>
    <field name="type">honeytrap</field>
    <description>T-Pot: Generic port probe on Honeytrap from $(srcip)</description>
    <group>honeypot,recon</group>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

  <!-- Multiple honeypot hits from same source (potential coordinated attack) -->
  <rule id="200005" level="14">
    <if_sid>200001</if_sid>
    <same_source_ip />
    <description>T-Pot: Multiple honeypot services probed from same source $(srcip)</description>
    <group>honeypot,recon,coordinated_attack</group>
    <options>no_full_log</options>
    <timeframe>60</timeframe>
    <frequency>3</frequency>
  </rule>

</group>
